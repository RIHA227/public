{
  "version": 2,
  "builds": [
    { "src": "api/market.js", "use": "@vercel/node" },
    { "src": "api/api/predict.js", "use": "@vercel/node" },
    { "src": "api/api/public/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/market", "dest": "/api/market.js" },
    { "src": "/api/predict", "dest": "/api/api/predict.js" },
    { "src": "/(.*)", "dest": "/api/api/public/index.html" }
  ]
}
